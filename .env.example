# AI job-tailoring (CV tailoring + cover letter) via OpenRouter.
# Copy this file to ".env" and fill in your key. ".env" is gitignored.
#
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use, in OpenRouter "provider/model" form. One key gives you access
# to many models — swap freely. Examples:
#   openai/gpt-4o-mini        (cheap, fast — the default if unset)
#   openai/gpt-4o
#   anthropic/claude-3.7-sonnet
#   google/gemini-2.0-flash
OPENROUTER_MODEL=openai/gpt-4o-mini

# Company research crawl bounds (only used when "Research the company online" is
# on). All optional — these are the defaults. Higher = more context but slower
# and more tokens/cost per tailor + cover letter.
#   RESEARCH_MAX_PAGES  pages to read, including the homepage
#   RESEARCH_PER_PAGE   characters kept per page
#   RESEARCH_TOTAL_CAP  overall character cap across all pages
RESEARCH_MAX_PAGES=6
RESEARCH_PER_PAGE=2200
RESEARCH_TOTAL_CAP=12000

# Optional Jina Reader API key (https://jina.ai/reader). Used for URL job-posting
# fetches and company research. With a key, r.jina.ai is faster and has much
# higher rate limits; without one it falls back to the free anonymous tier.
JINA_API_KEY=

# Verbose AI diagnostics:
#   DEBUG=1 (or true/yes/on) — compact summaries (cv source, sizes, cache hit/miss)
#   DEBUG=verbose (or full/2) — compact + full job posting, company research & extra context
DEBUG=
