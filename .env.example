# AI job-tailoring (CV tailoring + cover letter) via OpenRouter.
# Copy this file to ".env" and fill in your key. ".env" is gitignored.
#
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use, in OpenRouter "provider/model" form. One key gives you access
# to many models — swap freely. Examples:
#   openai/gpt-4o-mini        (cheap, fast — the default if unset)
#   openai/gpt-4o
#   anthropic/claude-3.7-sonnet
#   google/gemini-2.0-flash
OPENROUTER_MODEL=openai/gpt-4o-mini
